rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /permisos_chunks/{doc}   { allow read, write: if true; }
    match /permisos_meta/{doc}     { allow read, write: if true; }
    match /actas_chunks/{doc}      { allow read, write: if true; }
    match /actas_meta/{doc}        { allow read, write: if true; }
    match /usuarios/{doc}          { allow read, write: if true; }
    match /personal_config/{doc}   { allow read, write: if true; }

    // Antes: un documento por persona (mucho consumo de lecturas). Ahora,
    // chunks de hasta 500 registros con un mapa {personaId: {...datos}}
    // adentro, y un doc de índice con la cantidad de chunks.
    match /nomina_chunks/{doc}     { allow read, write: if true; }
    match /nomina_meta/{doc}       { allow read, write: if true; }

    // Antes: un documento por novedad. Mismo esquema de chunks que nomina.
    match /novedades_chunks/{doc}  { allow read, write: if true; }
    match /novedades_meta/{doc}    { allow read, write: if true; }

    // Antes: distribuciones/{fecha}/asignaciones/{personaId}, un documento
    // por persona y por día. Ahora es un solo documento por fecha con un
    // mapa {personaId: zona} adentro (mismo motivo: menos lecturas).
    match /distribuciones/{fecha} {
      allow read, write: if true;
      match /asignaciones/{personaId} {
        allow read, write: if true;
      }
    }
  }
}
