{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      ".env",
      ".env.example",
      "generate-config.js",
      "README.md",
      ".gitignore",
      "node_modules"
    ],
    "headers": [
      {
        "source": "/{estilo-comun.css,utils.js,personal-nav.js,personal-auth.js,personal-dominio.js,personal-datos.js}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      }
    ]
  }
}